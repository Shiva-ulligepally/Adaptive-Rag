{
  "version": 2,
  "functions": {
    "backend/server.js": {
      "maxDuration": 30,
      "includeFiles": "backend/documents/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/dist/$1"
    }
  ]
}
